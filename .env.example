# Copy these values to the Dokploy Compose "Environment" tab.
# Never commit real production secrets.

NODE_ENV=production
PORT=4000
BASE_URL=https://api.locafun.uz
# Comma-separated list of allowed frontend origins (no trailing slash).
FRONTEND_URL=https://market.vps.webdock.cloud,https://second-frontend.example.com

DB_HOST=market-db-2wwcav
POSTGRES_PORT=5432
POSTGRES_USER=market
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_DATABASE=market
# Keep false for an internal Dokploy PostgreSQL connection.
DB_SSL=false
# DB_SSL_REJECT_UNAUTHORIZED=true

JWT_SECRET=replace-with-at-least-32-random-characters
JWT_REFRESH_SECRET=replace-with-another-32-random-characters

# OpenSearch requires uppercase, lowercase, number and special character.
OPENSEARCH_URL=https://opensearch:9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=Replace-With-A-Strong-Password1!
OPENSEARCH_PRODUCTS_INDEX=products

# Rate limiting (per client IP). Defaults: 300 requests per 60 seconds.
# Static uploads and WebSocket traffic are not affected by these limits.
THROTTLE_TTL=60
THROTTLE_LIMIT=300

# Redis cache. Host/port are set by docker-compose (service name "redis").
# The password is required by the compose file.
REDIS_PASSWORD=replace-with-a-long-random-password
# Default cache TTL in seconds (per-endpoint TTLs override this).
CACHE_DEFAULT_TTL=60

# Cloudflare R2 object storage (S3-compatible) for image uploads.
# IMPORTANT: R2_ENDPOINT is the account endpoint WITHOUT the bucket name.
# (The S3 API URL shown in the R2 dashboard ends with "/locafun-img" — do NOT
#  include that suffix here; the bucket goes in R2_BUCKET.)
R2_ENDPOINT=https://8c3f76f2f0775a9a1fdc4f83c82a1a93.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=replace-with-r2-access-key-id
R2_SECRET_ACCESS_KEY=replace-with-r2-secret-access-key
R2_BUCKET=locafun-img
# Public base URL served via the R2 custom domain (no trailing slash).
R2_PUBLIC_URL=https://cdn.locafun.uz

# PM2 cluster workers. Default 2 (sized for the 1.5g api memory limit).
# Raise only together with the api mem_limit in docker-compose.yml.
PM2_INSTANCES=2
